          <span style={{ fontSize:"0.72rem", fontWeight:600, letterSpacing:"0.18em", color:"var(--gold)", textTransform:"uppercase" }}>
            Admissions Open 2025–26
          </span>
        </div>

        {/* Heading */}
        <h1 style={{
          fontFamily:"var(--display)",
          fontSize:"clamp(3.2rem, 9vw, 7.5rem)",
          fontWeight:700, lineHeight:1.04,
