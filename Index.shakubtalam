  const socials = [
    { icon:"📸", label:"Instagram", handle:"@shakuntalam_school" },
    { icon:"📘", label:"Facebook", handle:"/ShakuntalamSchool" },
    { icon:"▶️", label:"YouTube", handle:"Shakuntalam Official" },
