/* ─── FOOTER ────────────────────────────────────────────── */
function Footer() {
  const cols = [
    { title:"Quick Links", links:["About the School","Academic Programmes","Events & News","Student Results","Achievements","Gallery"] },
    { title:"Admissions", links:["Apply Now","Eligibility Criteria","Fee Structure","Scholarship Programme","Transfer Enquiry","Prospectus"] },
    { title:"Policies", links:["Privacy Policy","Terms of Use","Anti-Bullying Policy","POCSO Compliance","RTI / Grievances","Cookie Policy"] },
  ];

  return (
    <footer style={{ background:"#030308", borderTop:"1px solid var(--border)", padding:"80px 0 40px" }}>
      <div style={{ maxWidth:1180, margin:"0 auto", padding:"0 40px" }}>
        <div style={{ display:"grid", gridTemplateColumns:"1.8fr 1fr 1fr 1fr", gap:48, paddingBottom:60, borderBottom:"1px solid var(--border)", marginBottom:40 }} className="footer-grid">
          {/* Brand */}
          <div>
            <div style={{ display:"flex", alignItems:"center", gap:14, marginBottom:20 }}>
              <div style={{
                width:40, height:40, borderRadius:12,
                background:"linear-gradient(135deg,#c9a84c,#e8c96d)",
                display:"flex", alignItems:"center", justifyContent:"center",
                fontSize:"1.1rem", fontWeight:700, color:"#0a0a0a",
              }}>S</div>
              <div>
                <div style={{ fontFamily:"var(--display)", fontSize:"1.1rem", fontWeight:700 }}>Shakuntalam</div>
                <div style={{ fontSize:"0.6rem", letterSpacing:"0.14em", color:"var(--gold)", textTransform:"uppercase" }}>Banasthali Vidyapith</div>
              </div>
            </div>
            <p style={{ fontSize:"0.85rem", color:"var(--muted2)", lineHeight:1.75, maxWidth:280, marginBottom:28 }}>
              Shaping tomorrow's leaders through excellence in education, values, and innovation since 1982.
            </p>
            <div style={{ fontSize:"0.78rem", color:"var(--muted2)" }}>
              Banasthali, Rajasthan — 304022<br />
              CBSE Affiliation No. XXXXXX
            </div>
          </div>

          {cols.map((col, i) => (
            <div key={i}>
              <div style={{ fontSize:"0.68rem", fontWeight:600, letterSpacing:"0.16em", textTransform:"uppercase", color:"var(--muted2)", marginBottom:20 }}>{col.title}</div>
              <ul style={{ listStyle:"none", display:"flex", flexDirection:"column", gap:12 }}>
                {col.links.map(l => (
                  <li key={l}>
                    <a href="#" style={{
                      fontSize:"0.85rem", color:"rgba(240,237,232,0.4)",
                      textDecoration:"none", transition:"color 0.2s",
                    }}
                      onMouseEnter={e => e.currentTarget.style.color="var(--gold)"}
                      onMouseLeave={e => e.currentTarget.style.color="rgba(240,237,232,0.4)"}
                    >{l}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", flexWrap:"wrap", gap:16 }}>
          <div style={{ fontSize:"0.78rem", color:"rgba(240,237,232,0.25)" }}>
            © 2025 Shakuntalam School, Banasthali Vidyapith. All rights reserved.
          </div>
          <div style={{ display:"flex", gap:24 }}>
            {["Privacy","Terms","Sitemap"].map(l => (
              <a key={l} href="#" style={{
                fontSize:"0.78rem", color:"rgba(240,237,232,0.25)",
                textDecoration:"none", transition:"color 0.2s",
              }}
                onMouseEnter={e => e.currentTarget.style.color="var(--gold)"}
                onMouseLeave={e => e.currentTarget.style.color="rgba(240,237,232,0.25)"}
              >{l}</a>
            ))}
          </div>
        </div>
      </div>

      <style>{`
        @media (max-width: 900px) {
          .footer-grid { grid-template-columns: 1fr 1fr !important; }
        }
        @media (max-width: 600px) {
          .footer-grid { grid-template-columns: 1fr !important; }
        }
      `}</style>
    </footer>
  );
}

/* ─── APP ───────────────────────────────────────────────── */
export default function App() {
  const [activeSection, setActiveSection] = useState("hero");
  const scrollY = useScrollY();

  // Track active section
  useEffect(() => {
    const sections = ["hero","about","academics","events","results","achievements","gallery","contact"];
    const handleScroll = () => {
      for (let i = sections.length - 1; i >= 0; i--) {
        const el = document.getElementById(sections[i]);
        if (el && window.scrollY >= el.offsetTop - 200) {
          setActiveSection(sections[i]);
          break;
        }
      }
    };
    window.addEventListener("scroll", handleScroll, { passive:true });
    return () => window.removeEventListener("scroll", handleScroll);
  }, []);

  return (
    <div style={{ minHeight:"100vh", background:"var(--bg)" }}>
      <Nav active={activeSection} setActive={setActiveSection} />
      <Hero />
      <Ticker />
      <About />
      <Academics />
      <Events />
      <Results />
      <Achievements />
      <Gallery />
      <Contact />
      <Social />
      <Footer />

      {/* Back to top */}
      {scrollY > 600 && (
        <button
          onClick={() => window.scrollTo({ top:0, behavior:"smooth" })}
          style={{
            position:"fixed", bottom:32, right:32, zIndex:999,
            width:48, height:48, borderRadius:"50%",
            background:"linear-gradient(135deg,#c9a84c,#e8c96d)",
            border:"none", cursor:"pointer", fontSize:"1.1rem",
            boxShadow:"0 8px 30px rgba(201,168,76,0.35)",
            transition:"all 0.3s var(--ease)",
            display:"flex", alignItems:"center", justifyContent:"center",
            animation:"fadeIn 0.3s ease",
          }}
          onMouseEnter={e => { e.currentTarget.style.transform="translateY(-3px) scale(1.1)"; }}
          onMouseLeave={e => { e.currentTarget.style.transform="translateY(0) scale(1)"; }}
        >↑</button>
      )}
    </div>
  );
}
