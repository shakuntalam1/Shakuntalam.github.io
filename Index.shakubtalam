}

/* ─── NAV ───────────────────────────────────────────────── */
function Nav({ active, setActive }) {
  const scrollY = useScrollY();
  const [mobileOpen, setMobileOpen] = useState(false);
  const scrolled = scrollY > 60;

  const go = (id) => {
    document.getElementById(id)?.scrollIntoView({ behavior:"smooth" });
    setActive(id);
    setMobileOpen(false);
  };

  return (
    <>
      <nav style={{
        position:"fixed", top:0, left:0, right:0, zIndex:1000,
        height:68, display:"flex", alignItems:"center", justifyContent:"space-between",
        padding:"0 48px",
        background: scrolled ? "rgba(5,5,10,0.88)" : "transparent",
        backdropFilter: scrolled ? "blur(24px)" : "none",
        WebkitBackdropFilter: scrolled ? "blur(24px)" : "none",
        borderBottom: scrolled ? "1px solid var(--border)" : "1px solid transparent",
        transition:"all 0.5s var(--ease)",
      }}>
        {/* Logo */}
        <div style={{ display:"flex", alignItems:"center", gap:14, cursor:"pointer" }} onClick={() => go("hero")}>
          <div style={{
            width:40, height:40, borderRadius:12,
            background:"linear-gradient(135deg,#c9a84c,#e8c96d)",
            display:"flex", alignItems:"center", justifyContent:"center",
            fontSize:"1.1rem", fontWeight:700,
            boxShadow:"0 4px 20px rgba(201,168,76,0.3)",
          }}>S</div>
          <div>
            <div style={{ fontFamily:"var(--display)", fontSize:"1.1rem", fontWeight:700, letterSpacing:"0.02em", lineHeight:1.1 }}>Shakuntalam</div>
            <div style={{ fontSize:"0.62rem", letterSpacing:"0.15em", color:"var(--gold)", textTransform:"uppercase" }}>Banasthali Vidyapith</div>
          </div>
        </div>

        {/* Links */}
        <div style={{ display:"flex", alignItems:"center", gap:32 }} className="nav-desktop">
          {NAV_LINKS.map(l => (
            <button key={l.id} onClick={() => go(l.id)} style={{
              background:"none", border:"none", cursor:"pointer",
              fontSize:"0.82rem", fontWeight:400, letterSpacing:"0.02em",
              color: active === l.id ? "var(--gold)" : "rgba(240,237,232,0.65)",
              transition:"color 0.2s", padding:"4px 0", position:"relative",
              fontFamily:"var(--body)",
            }}>
              {l.label}
              {active === l.id && (
                <span style={{ position:"absolute", bottom:-2, left:0, right:0, height:1, background:"var(--gold)" }} />
              )}
            </button>
          ))}
          <button onClick={() => go("contact")} style={{
            padding:"9px 22px", borderRadius:100,
            background:"linear-gradient(135deg,#c9a84c,#e8c96d)",
            border:"none", cursor:"pointer",
            fontSize:"0.8rem", fontWeight:600, color:"#0a0a0a",
            letterSpacing:"0.02em", fontFamily:"var(--body)",
            transition:"all 0.3s var(--ease)",
            boxShadow:"0 4px 20px rgba(201,168,76,0.25)",
          }}
            onMouseEnter={e => e.currentTarget.style.boxShadow = "0 8px 30px rgba(201,168,76,0.5)"}
            onMouseLeave={e => e.currentTarget.style.boxShadow = "0 4px 20px rgba(201,168,76,0.25)"}
          >Enquire →</button>
        </div>

        {/* Hamburger */}
        <button onClick={() => setMobileOpen(!mobileOpen)} style={{
          display:"none", background:"none", border:"none", cursor:"pointer",
          padding:8, flexDirection:"column", gap:5,
        }} className="hamburger">
          <span style={{ display:"block", width:22, height:1.5, background:"var(--text)", transition:"all 0.3s" }} />
          <span style={{ display:"block", width:22, height:1.5, background:"var(--text)", transition:"all 0.3s" }} />
          <span style={{ display:"block", width:16, height:1.5, background:"var(--gold)", transition:"all 0.3s" }} />
        </button>
      </nav>

      {/* Mobile overlay */}
      {mobileOpen && (
        <div style={{
          position:"fixed", inset:0, zIndex:999,
          background:"rgba(5,5,10,0.98)", backdropFilter:"blur(20px)",
          display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", gap:32,
          animation:"fadeIn 0.3s ease",
        }}>
          <button onClick={() => setMobileOpen(false)} style={{
            position:"absolute", top:24, right:24, background:"none", border:"none",
            color:"var(--text)", cursor:"pointer", fontSize:"1.5rem",
          }}>✕</button>
          {NAV_LINKS.map(l => (
            <button key={l.id} onClick={() => go(l.id)} style={{
              background:"none", border:"none", cursor:"pointer",
              fontFamily:"var(--display)", fontSize:"2.2rem", fontWeight:400,
              color: active === l.id ? "var(--gold)" : "var(--text)",
            }}>{l.label}</button>
          ))}
        </div>
      )}

      <style>{`
        @media (max-width: 900px) {
          .nav-desktop { display: none !important; }
          .hamburger { display: flex !important; }
        }
      `}</style>
    </>
  );
}

/* ─── TICKER ────────────────────────────────────────────── */
function Ticker() {
  const doubled = [...TICKER_ITEMS, ...TICKER_ITEMS];
  return (
    <div style={{
      background:"linear-gradient(90deg, #c9a84c10, #c9a84c20, #c9a84c10)",
      borderTop:"1px solid rgba(201,168,76,0.2)",
      borderBottom:"1px solid rgba(201,168,76,0.2)",
      padding:"10px 0", overflow:"hidden", whiteSpace:"nowrap",
    }}>
      <div style={{ display:"flex", animation:"ticker 35s linear infinite" }}>
        {doubled.map((item, i) => (
          <span key={i} style={{
            padding:"0 48px", fontSize:"0.78rem", color:"rgba(201,168,76,0.9)",
            letterSpacing:"0.04em", display:"inline-flex", alignItems:"center", gap:8,
          }}>
            {item}
            <span style={{ color:"rgba(201,168,76,0.3)", marginLeft:24 }}>◆</span>
          </span>
        ))}
      </div>
    </div>
  );
}

