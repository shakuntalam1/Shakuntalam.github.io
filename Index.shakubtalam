            }}
              onMouseEnter={e => { e.currentTarget.style.borderColor="var(--gold)"; e.currentTarget.style.color="var(--gold)"; e.currentTarget.style.background="rgba(201,168,76,0.06)"; e.currentTarget.style.transform="translateY(-3px)"; }}
              onMouseLeave={e => { e.currentTarget.style.borderColor="var(--border)"; e.currentTarget.style.color="var(--muted)"; e.currenturrent.style.background="rgba(255,255,255,0.02)"; e.currentTarget.style.transform="translateY(0)"; }}
            >
              <span style={{ fontSize:"1.1rem" }}>{s.icon}</span>
              <span>{s.label}</span>
